Fixes for building release-e4e81cb3 with Gentoo's system packages:

1. CMakeLists.txt: drop version constraint and MODULE from find_package(Eigen3)
   so CMake uses Eigen3Config.cmake (from dev-cpp/eigen) instead of the bundled
   cmake_modules/FindEigen3.cmake, which reads Eigen/Version — a file that does
   not exist in Gentoo's Eigen 3.4 installation.
   Note: cmake_modules/FindEigen3.cmake is removed in src_prepare.

2. thirdparty/basalt-headers/CMakeLists.txt: fix ignore_external_warnings to
   use an allowlist of compilable target types instead of a blocklist; Pangolin's
   BUILDSYSTEM_TARGETS includes UTILITY (custom) targets which are not compilable,
   and the original INTERFACE_LIBRARY-only guard did not cover them.  Also guard
   ignore_external_warnings(eigen) behind if(TARGET eigen): the target only exists
   when using the bundled Eigen submodule; with BASALT_BUILTIN_EIGEN=OFF only
   Eigen3::Eigen is available.

--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -268,7 +268,7 @@
 set(CMAKE_CXX_FLAGS "${BASALT_CXX_FLAGS} ${BASALT_MARCH_FLAGS} ${BASALT_MCPU_FLAGS} ${BASALT_PASSED_CXX_FLAGS}")

 set(EIGEN_INCLUDE_DIR_HINTS ${EIGEN_ROOT})
-find_package(Eigen3 3.4.0 EXACT REQUIRED MODULE)
+find_package(Eigen3 REQUIRED)
 message(STATUS "Found Eigen headers in: ${EIGEN3_INCLUDE_DIR}")
 if(NOT EIGEN3_INCLUDE_DIR MATCHES "^${EIGEN_ROOT}")
   message(WARNING "Found Eigen headers are outside of specified EIGEN_ROOT '${EIGEN_ROOT}'")
--- a/thirdparty/basalt-headers/CMakeLists.txt
+++ b/thirdparty/basalt-headers/CMakeLists.txt
@@ -9,6 +9,7 @@
   # Silence compile warnings
   get_target_property(_target_type ${target} TYPE)
-  if(NOT _target_type STREQUAL "INTERFACE_LIBRARY")
+  if(_target_type MATCHES
+      "^(STATIC_LIBRARY|MODULE_LIBRARY|SHARED_LIBRARY|OBJECT_LIBRARY|EXECUTABLE)$")
     target_compile_options(${target} PRIVATE "-w")
   endif()

@@ -111,7 +112,9 @@
   message(STATUS "Eigen already available")
 endif()
 report_dependency_location(Eigen3 Eigen3::Eigen)
-ignore_external_warnings(eigen)
+if(TARGET eigen)
+  ignore_external_warnings(eigen)
+endif()

 option(BASALT_BUILTIN_SOPHUS "Use builtin Sophus from submodule" ON)
 if(NOT TARGET Sophus::Sophus)
